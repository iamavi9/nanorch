# NanoOrch Environment Configuration
# Copy this file to .env and fill in your values
#
# ─── _FILE pattern (Docker secrets) ──────────────────────────────────────────
# Every secret variable below supports a companion <NAME>_FILE variant.
# If <NAME>_FILE is set, the app reads the secret from that file instead of
# the plain env var.  Real values never appear in `docker inspect Env`.
#
# Example:
#   SESSION_SECRET_FILE=/run/secrets/session_secret
#
# Run  ./secrets/create-secrets.sh  and use docker-compose.secrets.yml for a
# fully hardened deployment.  See secrets/README.md for details.
# ─────────────────────────────────────────────────────────────────────────────

# ─── Database ────────────────────────────────────────────────────────────────
POSTGRES_DB=nanoorch
POSTGRES_USER=nanoorch
POSTGRES_PASSWORD=change_me_in_production
# DATABASE_URL is constructed from the above in docker-compose.yml.
# Set DATABASE_URL_FILE=/run/secrets/database_url when using Docker secrets.

# ─── App ─────────────────────────────────────────────────────────────────────
APP_PORT=3000

# Public URL of your NanoOrch instance (required for SSO OIDC/SAML callback URLs).
# Must be the full origin (scheme + host + optional port) that your identity provider
# will redirect to.  If unset, NanoOrch derives it from the incoming request headers
# (works correctly behind Nginx with X-Forwarded-Proto / X-Forwarded-Host).
#
# Examples:
#   APP_URL=https://nanoorch.your-company.com   (behind Nginx + SSL)
#   APP_URL=http://1.2.3.4:3000                 (direct EC2 access, no proxy)
APP_URL=

# Required — use a long random string (e.g. openssl rand -hex 32)
# _FILE variant: SESSION_SECRET_FILE=/run/secrets/session_secret
SESSION_SECRET=change_this_to_a_long_random_string_in_production

# ─── Admin Credentials ───────────────────────────────────────────────────────
# These seed the first admin account on startup (only if no admin exists yet).
# CHANGE ADMIN_PASSWORD before first boot — it cannot be changed via the UI later.
# _FILE variant: ADMIN_PASSWORD_FILE=/run/secrets/admin_password
ADMIN_USERNAME=admin
ADMIN_PASSWORD=change_me_before_first_boot

# ─── Credential Encryption ───────────────────────────────────────────────────
# 32-byte hex string for AES-256-GCM encryption of cloud integration credentials.
# Generate with: openssl rand -hex 32
# If left empty, the app derives a key from SESSION_SECRET (not recommended for production).
# _FILE variant: ENCRYPTION_KEY_FILE=/run/secrets/encryption_key
ENCRYPTION_KEY=

# ─── AI Providers ────────────────────────────────────────────────────────────
# At least one provider key is required. Others can be left blank.
# All keys support the _FILE variant:
#   AI_INTEGRATIONS_OPENAI_API_KEY_FILE=/run/secrets/openai_api_key
#   AI_INTEGRATIONS_ANTHROPIC_API_KEY_FILE=/run/secrets/anthropic_api_key
#   AI_INTEGRATIONS_GEMINI_API_KEY_FILE=/run/secrets/gemini_api_key

AI_INTEGRATIONS_OPENAI_API_KEY=
AI_INTEGRATIONS_OPENAI_BASE_URL=https://api.openai.com/v1

AI_INTEGRATIONS_ANTHROPIC_API_KEY=
AI_INTEGRATIONS_ANTHROPIC_BASE_URL=https://api.anthropic.com

AI_INTEGRATIONS_GEMINI_API_KEY=
AI_INTEGRATIONS_GEMINI_BASE_URL=https://generativelanguage.googleapis.com

# ─── Docker Agent Sandbox ────────────────────────────────────────────────────
# DOCKER_SOCKET tells the app Docker is available for isolated task execution.
DOCKER_SOCKET=/var/run/docker.sock

# AGENT_IMAGE: image for action-task agent containers (built from ./agent/Dockerfile)
AGENT_IMAGE=nanoorch-agent:latest

# SANDBOX_IMAGE: image for code-execution sandbox containers (built from ./agent/sandbox/)
SANDBOX_IMAGE=nanoorch-sandbox:latest

# ─── Runtime isolation ───────────────────────────────────────────────────────
# SANDBOX_RUNTIME: OCI runtime for code-execution sandbox containers.
#   runsc  — gVisor kernel-level isolation (requires gVisor installed on host)
#   runc   — standard Docker runtime (no gVisor needed)
SANDBOX_RUNTIME=runsc

# AGENT_RUNTIME: OCI runtime for agent action-task containers.
#   runsc  — gVisor isolation (recommended for production)
#   runc   — standard Docker runtime
#   (blank) — use Docker's default (runc)
AGENT_RUNTIME=

# SECCOMP_PROFILE: absolute host path to a custom seccomp JSON profile.
# Applied to both agent and sandbox containers when set.
# A hardened profile is included at agent/seccomp/nanoorch.json.
# Copy it to a stable host path and set:
#   SECCOMP_PROFILE=/etc/nanoorch/seccomp/nanoorch.json
SECCOMP_PROFILE=
