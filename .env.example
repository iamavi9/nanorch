# NanoOrch Environment Configuration
# Copy this file to .env and fill in your values

# ─── Database ────────────────────────────────────────────────────────────────
POSTGRES_DB=nanoorch
POSTGRES_USER=nanoorch
POSTGRES_PASSWORD=change_me_in_production

# ─── App ─────────────────────────────────────────────────────────────────────
APP_PORT=3000
SESSION_SECRET=change_this_to_a_long_random_string_in_production

# ─── Admin Credentials ───────────────────────────────────────────────────────
# These seed the first admin account on startup (only if no admin exists yet).
# CHANGE ADMIN_PASSWORD before first boot — it cannot be changed from the UI.
ADMIN_USERNAME=admin
ADMIN_PASSWORD=change_me_before_first_boot

# ─── Credential Encryption ───────────────────────────────────────────────────
# 32-byte hex string for AES-256-GCM encryption of cloud integration credentials.
# Generate with: openssl rand -hex 32
# If left empty, the app derives a key from SESSION_SECRET (not recommended for production).
ENCRYPTION_KEY=

# ─── AI Providers ────────────────────────────────────────────────────────────
# At least one provider key is required. Others can be left blank.

AI_INTEGRATIONS_OPENAI_API_KEY=
AI_INTEGRATIONS_OPENAI_BASE_URL=https://api.openai.com/v1

AI_INTEGRATIONS_ANTHROPIC_API_KEY=
AI_INTEGRATIONS_ANTHROPIC_BASE_URL=https://api.anthropic.com

AI_INTEGRATIONS_GEMINI_API_KEY=
AI_INTEGRATIONS_GEMINI_BASE_URL=https://generativelanguage.googleapis.com

# ─── Docker Agent Sandbox ────────────────────────────────────────────────────
# DOCKER_SOCKET tells the app Docker is available for isolated task execution.
# AGENT_IMAGE is the image built from ./agent/Dockerfile.
DOCKER_SOCKET=/var/run/docker.sock
AGENT_IMAGE=nanoorch-agent:latest
SANDBOX_IMAGE=nanoorch-sandbox:latest
# Set to runc if gVisor (runsc) is not installed on the host
SANDBOX_RUNTIME=runsc
