{
  "$schema": "https://github.com/opencontainers/runtime-spec/raw/main/schema/config-schema.json#/definitions/Linux/properties/seccomp",
  "_comment": "NanoOrch seccomp profile — tighter than Docker's default. Blocks privilege-escalation syscalls that Docker normally allows (capset, setuid*, setgid*) in addition to the kernel-dangerous calls Docker already blocks. Apply with: --security-opt seccomp=/path/to/nanoorch.json",
  "defaultAction": "SCMP_ACT_ERRNO",
  "defaultErrnoRet": 1,
  "architectures": [
    "SCMP_ARCH_X86_64",
    "SCMP_ARCH_X86",
    "SCMP_ARCH_X32",
    "SCMP_ARCH_AARCH64",
    "SCMP_ARCH_ARM"
  ],
  "syscalls": [
    {
      "_comment": "Standard file I/O",
      "names": [
        "read", "write", "open", "openat", "openat2", "close",
        "stat", "fstat", "lstat", "fstatat64", "newfstatat", "statx",
        "lseek", "mmap", "mprotect", "munmap", "brk",
        "pread64", "pwrite64", "readv", "writev", "preadv", "pwritev", "preadv2", "pwritev2",
        "access", "faccessat", "faccessat2",
        "pipe", "pipe2", "dup", "dup2", "dup3",
        "select", "pselect6", "poll", "ppoll",
        "fcntl", "fcntl64", "flock", "fsync", "fdatasync",
        "truncate", "truncate64", "ftruncate", "ftruncate64",
        "getdents", "getdents64", "getcwd", "chdir", "fchdir",
        "rename", "renameat", "renameat2",
        "mkdir", "mkdirat", "rmdir", "creat",
        "link", "linkat", "unlink", "unlinkat",
        "symlink", "symlinkat", "readlink", "readlinkat",
        "chmod", "fchmod", "fchmodat", "chown", "fchown", "fchown32",
        "fchownat", "lchown", "lchown32", "umask",
        "sendfile", "sendfile64",
        "stat64", "lstat64", "fstat64",
        "statfs", "statfs64", "fstatfs", "fstatfs64",
        "fallocate", "readahead", "fadvise64",
        "sync", "syncfs", "sync_file_range",
        "mknod", "mknodat",
        "tee", "splice", "copy_file_range",
        "getxattr", "lgetxattr", "fgetxattr",
        "setxattr", "lsetxattr", "fsetxattr",
        "listxattr", "llistxattr", "flistxattr",
        "removexattr", "lremovexattr", "fremovexattr"
      ],
      "action": "SCMP_ACT_ALLOW"
    },
    {
      "_comment": "Memory management",
      "names": [
        "mmap2", "madvise", "mincore", "mlock", "mlock2", "mlockall",
        "munlock", "munlockall", "msync", "mremap", "remap_file_pages",
        "memfd_create", "process_madvise"
      ],
      "action": "SCMP_ACT_ALLOW"
    },
    {
      "_comment": "Process control — clone without CLONE_NEWUSER so namespace creation is still blocked",
      "names": [
        "fork", "vfork", "execve", "execveat",
        "wait4", "waitid", "waitpid",
        "exit", "exit_group",
        "getpid", "getppid", "gettid",
        "getuid", "getuid32", "geteuid", "geteuid32",
        "getgid", "getgid32", "getegid", "getegid32",
        "getgroups", "getgroups32",
        "getresuid", "getresuid32", "getresgid", "getresgid32",
        "getpgid", "getpgrp", "getsid", "setpgid", "setsid",
        "getitimer", "setitimer", "alarm",
        "getpriority", "setpriority",
        "getrlimit", "setrlimit", "prlimit64", "ugetrlimit", "getrusage",
        "times", "utime", "utimes", "utimensat", "futimesat",
        "time", "gettimeofday", "clock_gettime", "clock_getres",
        "clock_nanosleep", "nanosleep",
        "getcpu", "sysinfo", "uname",
        "sched_yield", "sched_getaffinity", "sched_setaffinity",
        "sched_getparam", "sched_setparam",
        "sched_getscheduler", "sched_setscheduler",
        "sched_get_priority_max", "sched_get_priority_min",
        "sched_getattr", "sched_setattr",
        "ioprio_get", "ioprio_set",
        "arch_prctl", "prctl",
        "set_tid_address", "set_robust_list", "get_robust_list",
        "set_thread_area", "get_thread_area",
        "restart_syscall", "rseq"
      ],
      "action": "SCMP_ACT_ALLOW"
    },
    {
      "_comment": "clone — allow but only without CLONE_NEWUSER (0x10000000).  Covers threads (CLONE_THREAD) and subprocesses.",
      "names": ["clone"],
      "action": "SCMP_ACT_ALLOW",
      "args": [
        {
          "index": 0,
          "value": 2114060288,
          "op": "SCMP_CMP_MASKED_EQ",
          "valueTwo": 0
        }
      ]
    },
    {
      "_comment": "clone3 — allow without unshare/newuser flags",
      "names": ["clone3"],
      "action": "SCMP_ACT_ALLOW"
    },
    {
      "_comment": "Signals",
      "names": [
        "rt_sigaction", "rt_sigprocmask", "rt_sigreturn", "rt_sigpending",
        "rt_sigsuspend", "rt_sigtimedwait", "rt_sigqueueinfo", "rt_tgsigqueueinfo",
        "signal", "sigaltstack", "sigprocmask", "sigreturn", "sigsuspend", "sigpending",
        "signalfd", "signalfd4",
        "kill", "tkill", "tgkill", "pause"
      ],
      "action": "SCMP_ACT_ALLOW"
    },
    {
      "_comment": "I/O multiplexing + async I/O",
      "names": [
        "epoll_create", "epoll_create1", "epoll_ctl", "epoll_wait",
        "epoll_pwait", "epoll_pwait2",
        "inotify_init", "inotify_init1", "inotify_add_watch", "inotify_rm_watch",
        "eventfd", "eventfd2",
        "timerfd_create", "timerfd_settime", "timerfd_gettime",
        "io_setup", "io_destroy", "io_getevents", "io_submit", "io_cancel",
        "io_pgetevents",
        "io_uring_setup", "io_uring_enter", "io_uring_register",
        "timer_create", "timer_settime", "timer_gettime",
        "timer_getoverrun", "timer_delete"
      ],
      "action": "SCMP_ACT_ALLOW"
    },
    {
      "_comment": "Networking — needed by runtimes (Node.js event loop, Python requests, etc.)",
      "names": [
        "socket", "connect", "bind", "listen", "accept", "accept4",
        "shutdown", "getsockname", "getpeername", "socketpair",
        "setsockopt", "getsockopt",
        "sendmsg", "recvmsg", "sendmmsg", "recvmmsg",
        "send", "recv", "sendto", "recvfrom",
        "socketcall"
      ],
      "action": "SCMP_ACT_ALLOW"
    },
    {
      "_comment": "Shared memory + IPC (needed by some language runtimes)",
      "names": [
        "shmget", "shmat", "shmdt", "shmctl",
        "msgget", "msgsnd", "msgrcv", "msgctl",
        "semget", "semop", "semtimedop", "semctl",
        "mq_open", "mq_unlink", "mq_timedsend", "mq_timedreceive",
        "mq_notify", "mq_getsetattr",
        "ipc"
      ],
      "action": "SCMP_ACT_ALLOW"
    },
    {
      "_comment": "Capability query — reading caps is safe; capset (writing) is NOT in this list",
      "names": ["capget"],
      "action": "SCMP_ACT_ALLOW"
    },
    {
      "_comment": "Misc safe calls",
      "names": [
        "ioctl", "getrandom", "seccomp",
        "syslog", "membarrier",
        "futex",
        "vmsplice", "sendfile",
        "lseek", "umask"
      ],
      "action": "SCMP_ACT_ALLOW"
    }
  ]
}
